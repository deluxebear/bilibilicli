{
  "name": "@deluxebear/bilibilicli",
  "version": "0.1.0",
  "description": "Local CLI for browser-assisted Bilibili video uploads.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deluxebear/bilibilicli.git"
  },
  "bugs": {
    "url": "https://github.com/deluxebear/bilibilicli/issues"
  },
  "homepage": "https://github.com/deluxebear/bilibilicli#readme",
  "keywords": [
    "bilibili",
    "cli",
    "upload",
    "video",
    "automation"
  ],
  "bin": {
    "bilibilicli": "./bin/bilibilicli.mjs"
  },
  "files": [
    "bin/",
    "lib/",
    "README.md"
  ],
  "scripts": {
    "check": "node --check bin/bilibilicli.mjs && node --check lib/*.mjs",
    "prepack": "npm run check",
    "pack:dry": "npm pack --dry-run"
  },
  "dependencies": {
    "playwright": "^1.59.1"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
